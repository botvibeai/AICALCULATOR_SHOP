rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- USER PROFILE RULES ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == userId
          && data.email is string && data.email.size() <= 256
          && data.points is number && data.points >= 0
          && data.credits is number && data.credits >= 0
          && (data.savedCalculators is list || !data.keys().hasAny(['savedCalculators']))
          && (data.savedCalculators.size() <= 200 || !data.keys().hasAny(['savedCalculators']));
      }

      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().points == 120 // Initial points enforce
        && incoming().credits == 5; // Initial credits enforce

      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action: Point increment/decrement or credits change
          incoming().diff(existing()).affectedKeys().hasOnly(['points', 'credits', 'updatedAt', 'savedCalculators', 'displayName'])
        );

      // --- ACTIVITY LOG RULES ---
      match /activities/{activityId} {
        function isValidActivity(data) {
          return data.userId == userId
            && data.action is string && data.action.size() <= 50
            && (data.toolId == null || (data.toolId is string && data.toolId.size() <= 64))
            && data.pointsEarned is number
            && data.timestamp == request.time;
        }

        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidActivity(incoming());
      }
    }
  }
}
